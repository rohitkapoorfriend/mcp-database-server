{
  "name": "mcp-database-server",
  "version": "1.0.0",
  "description": "MCP server that enables AI agents to securely query and analyze databases",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mcp-database-server": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "database",
    "ai",
    "claude",
    "postgresql",
    "mysql",
    "mongodb"
  ],
  "author": "Ravi Kumar",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pg": "^8.13.1",
    "mysql2": "^3.12.0",
    "mongodb": "^6.12.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "typescript-eslint": "^8.18.0",
    "eslint": "^9.16.0"
  }
}
